# AI 接口配置（可配置 base_url 与 api_key）
# AI_API_KEY: 必填，用于调用 AI API 的密钥（Gemini API Key 或 DeepSeek/OpenAI 兼容服务的 key）
AI_API_KEY="YOUR_AI_API_KEY"

# AI_BASE_URL: 可选。不填则使用 Gemini 官方端点；填写则走 OpenAI 兼容格式（如 DeepSeek）
# DeepSeek 示例: https://api.deepseek.com/v1
AI_BASE_URL=""

# AI_MODEL: 仅当设置了 AI_BASE_URL（OpenAI 兼容）时生效，模型名，默认 deepseek-chat
AI_MODEL="deepseek-chat"

# 兼容旧配置：若未设置 AI_API_KEY，会回退使用 GEMINI_API_KEY
# GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
